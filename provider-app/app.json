{
  "expo": {
    "name": "provider-app",
    "slug": "provider-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easycare.provider",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EasyCare Provider needs your location to show your position to customers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "EasyCare Provider tracks your location in the background so customers can find you."
      },
      "config": {}
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.easycare.provider",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "INTERNET"
      ],
      "config": {}
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EasyCare Provider needs your location to show your position to customers.",
          "locationAlwaysAndWhenInUsePermission": "EasyCare Provider tracks your location in the background so customers can find you.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
